# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test, coverage, and tooling cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Runtime data
storage/uploads/*
!storage/uploads/.gitkeep
storage/history.db


# Keep folder structure placeholders
!storage/.gitkeep
!model/.gitkeep
